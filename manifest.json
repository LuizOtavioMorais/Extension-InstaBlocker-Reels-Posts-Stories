{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "3.0",
  "description": "__MSG_extDesc__",
  "default_locale": "pt_BR",
  "browser_specific_settings": {
    "gecko": {
      "id": "{f14a6012-328c-48c9-b883-9b2511cd981d}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
